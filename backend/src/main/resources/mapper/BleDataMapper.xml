<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wanling.backend.mapper.BleDataMapper">
    <insert id="insert" parameterType="com.wanling.backend.entity.BleData">
        INSERT INTO ble_data (temperature, humidity, timestamp)
        VALUES (#{temperature}, #{humidity}, #{timestamp})
    </insert>
</mapper>
